{
  "enabled": true,
  "name": "Cheap Gate on Save",
  "description": "Runs typecheck, lint, and unit tests on every saved TS/TSX file to catch breakage before Kane ever fires.",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "src/**/*.ts",
      "src/**/*.tsx"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "npm run typecheck && npm run lint && npm run test -- --run"
  }
}