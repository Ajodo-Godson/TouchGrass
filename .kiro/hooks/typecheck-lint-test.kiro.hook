{
  "name": "Cheap Gate on Save",
  "version": "1.0.0",
  "description": "Runs typecheck and unit tests on every saved TS/TSX file to catch breakage before Kane ever fires. (Add 'npm run lint' once the ESLint token rule from task 7.1 lands.)",
  "when": {
    "type": "fileEdited",
    "patterns": ["src/**/*.ts", "src/**/*.tsx"]
  },
  "then": {
    "type": "runCommand",
    "command": "npm run typecheck && npm run test -- --run"
  }
}
