# Supabase configuration (Requirement 11.2, 11.3).
# Copy to .env and fill in your project values. Without these, the app renders
# the ConfigError screen (Requirement 11.4).
# Use the anon/publishable key here, NEVER the service/secret key — anything
# prefixed VITE_ is bundled into the shipped frontend.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
